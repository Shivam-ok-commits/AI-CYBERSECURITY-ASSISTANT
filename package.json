{
  "name": "sentinel",
  "version": "1.0.0",
  "private": true,
  "description": "Sentinel — AI-Powered Security Operations Platform",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:legacy": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "build": "cd frontend && npm run build && cd ../electron && npm run build",
    "build:backend": "powershell -ExecutionPolicy Bypass -File scripts/build-backend.ps1",
    "package": "powershell -ExecutionPolicy Bypass -File scripts/package.ps1",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force 'frontend/dist', 'electron/dist', 'electron/release', 'dist/backend', 'build' -ErrorAction SilentlyContinue; Write-Host 'Cleaned'\""
  },
  "devDependencies": {
    "concurrently": "^9.1.1"
  }
}
